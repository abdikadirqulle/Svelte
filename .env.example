# Copy to .env and fill in values. No quotes needed around values.

# App URL — must match the browser address (no trailing slash)
ORIGIN=http://localhost:5173

# Supabase → Settings → Database
# Use "URI" and prefer Direct connection (port 5432), e.g.:
# postgresql://postgres.[ref]:[YOUR-DB-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
# Or host: db.xxxxx.supabase.co port 5432
DATABASE_URL=

# Random string, 32+ characters (any generator is fine for local dev)
BETTER_AUTH_SECRET=

# GitHub → Settings → Developer settings → OAuth Apps
# Authorization callback URL: http://localhost:5173/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
